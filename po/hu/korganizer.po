#. i18n: ectx: tooltip, entry (ShowEndTimeInMonthView), group (Month View)
#: settings/korganizer.kcfg:235
#, kde-format
msgid "Display the start and end times in month view items"
msgstr "Kezdési és befejezési időpontok megjelenítése a havi nézetben"

#. i18n: ectx: whatsthis, entry (ShowTodosMonthView), group (Month View)
#: settings/korganizer.kcfg:240
#, kde-format
msgid "Check this box to display to-dos in the month view."
msgstr "Jelölje be ezt a négyzetet a teendők havi nézetben történő megjelenítéséhez."

#. i18n: ectx: tooltip, entry (ShowTodosMonthView), group (Month View)
#: settings/korganizer.kcfg:241
#, kde-format
msgid "Display to-dos in the month view"
msgstr "Teendők megjelenítése havi nézetben"

#. i18n: ectx: label, entry (ShowJournalsMonthView), group (Month View)
#: settings/korganizer.kcfg:245
#, kde-format
msgid "Show journals"
msgstr "Naplók megjelenítése"

#. i18n: ectx: whatsthis, entry (ShowJournalsMonthView), group (Month View)
#: settings/korganizer.kcfg:246
#, kde-format
msgid "Check this box to display journals in the month view."
msgstr "Jelölje be ezt a négyzetet a naplók havi nézetben való megjelenítéséhez."

#. i18n: ectx: tooltip, entry (ShowJournalsMonthView), group (Month View)
#: settings/korganizer.kcfg:247
#, kde-format
msgid "Display journals in the month view"
msgstr "Naplók megjelenítése havi nézetben"

#. i18n: ectx: label, entry (ShowHolidaysMonthView), group (Month View)
#: settings/korganizer.kcfg:251
#, kde-format
msgid "Show holidays"
msgstr "Ünnepnapok megjelenítése"

#. i18n: ectx: whatsthis, entry (ShowHolidaysMonthView), group (Month View)
#: settings/korganizer.kcfg:252
#, kde-format
msgid "Check this box to display holidays in the month view."
msgstr "Jelölje be ezt a négyzetet az ünnepnapok havi nézetben történő megjelenítéséhez."

#. i18n: ectx: tooltip, entry (ShowHolidaysMonthView), group (Month View)
#. i18n: ectx: tooltip, entry (ShowHolidaysBackgroundMonthView), group (Month View)
#: settings/korganizer.kcfg:253 settings/korganizer.kcfg:260
#, kde-format
msgid "Display holidays in the month view"
msgstr "Ünnepnapok megjelenítése a havi nézetben"

#. i18n: ectx: label, entry (ShowHolidaysBackgroundMonthView), group (Month View)
#: settings/korganizer.kcfg:257
#, kde-format
msgid "Use the Holiday background color when a holiday lands on the date"
msgstr "Ha az adott nap ünnepnapra esik, használja az ünnepi háttérszínt"

#. i18n: ectx: tooltip, entry (ShowHolidaysBackgroundMonthView), group (Month View)
#: settings/korganizer.kcfg:258
#, kde-format
msgid ""
"Use the custom holiday color as the date's background color if a holiday "
"lands on the date"
msgstr "Ha az adott nap ünnepnapra esik, akkor az ünnepnaphoz rendelt színt használja a dátum háttérszínének"

#. i18n: ectx: whatsthis, entry (ShowHolidaysBackgroundMonthView), group (Month View)
#: settings/korganizer.kcfg:259
#, kde-format
msgid ""
"Check this box to use the custom holiday as the date's background color when "
"at least one holiday lands on a date. Configure the holiday color in the "
"Settings->Colors and Fonts."
msgstr "Jelölje be ezt a jelölőnégyzetet, ha azt szeretné, hogy az adott nap háttérszíne az egyéni ünnep színe legyen, amennyiben az adott napra legalább egy ünnep esik. Beállíthatja az ünnepnap színét, a Beállítások->Színek és Betűtípusok menüpontban.\n"

#. i18n: ectx: label, entry, group (Month View)
#: settings/korganizer.kcfg:264
#, kde-format
msgid "Month view uses full window"
msgstr "A havi nézet teljes ablakot használjon"

#. i18n: ectx: whatsthis, entry, group (Month View)
#: settings/korganizer.kcfg:265
#, kde-format
msgid ""
"Check this box to use the full KOrganizer window when displaying the month "
"view. If this box is checked, you will gain some space for the monthly view, "
"but other widgets, such as the date navigator, the item details and the "
"calendars list, will not be displayed."
msgstr "Jelölje be ezt a négyzetet, ha a KOrganizer teljes ablakát szeretné használni a havi nézet megjelenítésekor. Ha ezt a jelölőnégyzetet bejelöli, több hely marad a havi nézet számára, viszont más modulok – például a dátumnavigátor, az elem adatok és a naptárlista – nem jelennek meg."

#. i18n: ectx: tooltip, entry, group (Month View)
#: settings/korganizer.kcfg:274
#, kde-format
msgid ""
"Draw month items with their tag color inside and calendar color for their "
"border"
msgstr "Rajzolja meg a hónap elemeit a címke színével, és a keretüket a naptár színével"

#. i18n: ectx: tooltip, entry, group (Month View)
#: settings/korganizer.kcfg:279
#, kde-format
msgid ""
"Draw month items with their calendar color inside and tag color for their "
"border"
msgstr "Rajzolja a hónap elemeket belül a naptár színével, és a címke színével a keretüket"

#. i18n: ectx: whatsthis, entry, group (Month View)
#: settings/korganizer.kcfg:283
#, kde-format
msgid ""
"Select the \"Only tag\" option if you would like to draw calendar items "
"(both inside and border) in the color of their associated tag.  Please use "
"the Colors and Fonts configuration page for setting these colors."
msgstr "Válassza a \"Csak címke\" opciót, ha a naptárelemeket (a belsejüket és a keretet is) a hozzájuk tartozó címke színével szeretné megrajzolni.  Ezeket a színeket beállíthatja a Színek és Betűtípusok oldalon."

#. i18n: ectx: tooltip, entry, group (Month View)
#: settings/korganizer.kcfg:284
#, kde-format
msgid "Draw month items using their tag color for the inside and border"
msgstr "A hónap elemeinek belső részét és a keretet is, a címke színével rajzolja meg"

#. i18n: ectx: whatsthis, entry, group (Month View)
#: settings/korganizer.kcfg:288
#, kde-format
msgid ""
"Select the \"Only calendar\" option if you would like to draw calendar items "
"(both inside and border) in the color of their calendar.  Please use the "
"Colors and Fonts configuration page for setting these colors."
msgstr "Válassza a \"Csak naptár\" opciót, ha a naptárelemeket (a belsejét és a keretet is) a naptár színével szeretné rajzolni.  Ezeket a színeket beállíthatja a Színek és Betűtípusok oldalon."

#. i18n: ectx: tooltip, entry, group (Month View)
#: settings/korganizer.kcfg:289
#, kde-format
msgid "Draw month items using their calendar color for the inside and border"
msgstr "A hónap elemeinek belső részét és a keretet is, a naptár színével rajzolja meg"

#. i18n: ectx: label, entry, group (Todo View)
#: settings/korganizer.kcfg:298
#, kde-format
msgid "Always display completed to-dos at the bottom of the list"
msgstr "Mindig a lista alján jelenítse meg a befejezett teendőket"

#. i18n: ectx: tooltip, entry, group (Todo View)
#: settings/korganizer.kcfg:299
#, kde-format
msgid ""
"Completed to-dos are displayed at the bottom of the list, regardless of "
"priority"
msgstr "A befejezett feladatok a lista alján jelenjenek meg, prioritástól függetlenül."

#. i18n: ectx: whatsthis, entry, group (Todo View)
#: settings/korganizer.kcfg:300
#, kde-format
msgid ""
"Check this box if you want all completed to-dos to be always grouped at the "
"bottom of the to-do list."
msgstr "Jelölje be ezt a négyzetet, ha azt szeretné, hogy az összes befejezett feladat mindig a teendő lista alján legyen csoportosítva."

#. i18n: ectx: label, entry, group (Todo View)
#: settings/korganizer.kcfg:304
#, kde-format
msgid "To-do list view uses full window"
msgstr "A teendő lista nézet használja a teljes ablakot"

#. i18n: ectx: tooltip, entry, group (Todo View)
#: settings/korganizer.kcfg:305
#, kde-format
msgid "Display to-do list in a full KOrganizer window"
msgstr "A teendő lista megjelenítése a KOrganizer teljes ablakában"

#. i18n: ectx: whatsthis, entry, group (Todo View)
#: settings/korganizer.kcfg:306
#, kde-format
msgid ""
"Check this box to use the full KOrganizer window when displaying the to-do "
"list view. If this box is checked, you will gain some space for the to-do "
"list view, but other widgets, such as the date navigator, the to-do details "
"and the calendars list, will not be displayed."
msgstr "Jelölje be ezt a négyzetet, ha a teljes KOrganizer ablakot szeretné használni a teendő lista nézet megjelenítésekor. Ha ez a négyzet be van jelölve, akkor némi helyet nyer a teendő lista nézetnek, de más modulok, például a dátumnavigátor, a teendők részletei és a naptárak listája nem jelenik meg."

#. i18n: ectx: label, entry, group (Todo View)
#: settings/korganizer.kcfg:310
#, kde-format
msgid "Display to-dos in a flat list"
msgstr "Teendők megjelenítése egyszerű listában"

#. i18n: ectx: tooltip, entry, group (Todo View)
#: settings/korganizer.kcfg:311
#, kde-format
msgid "Display to-dos as a flat list instead of a hierarchical tree"
msgstr "A teendőket hierarchikus fa helyett sima listaként jeleníti meg"

#. i18n: ectx: whatsthis, entry, group (Todo View)
#: settings/korganizer.kcfg:312
#, kde-format
msgid ""
"Check this box if you want to see all your to-dos in a flat list instead of "
"being arranged in a hierarchical tree."
msgstr "Jelölje be ezt a négyzetet, ha az összes tennivalót egy sima listában szeretné látni ahelyett, hogy hierarchikus fába rendezné őket."

#. i18n: ectx: label, entry, group (Todo View)
#: settings/korganizer.kcfg:316
#, kde-format
msgid "Record completed to-dos in journal entries"
msgstr "Az elvégzett teendők naplóbejegyzésekben történő rögzítése"

#. i18n: ectx: whatsthis, entry, group (Todo View)
#: settings/korganizer.kcfg:317
#, kde-format
msgid ""
"Check this box to record the completion of a to-do in a new entry of your "
"journal automatically."
msgstr "Jelölje be ezt a négyzetet, hogy a teendők elvégzését automatikusan rögzítse a napló egy új bejegyzésében."

#. i18n: ectx: label, entry, group (Colors)
#. i18n: ectx: label, entry, group (Theming)
#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:324 settings/korganizer.kcfg:529
#: settings/korganizer.kcfg:637
#, kde-format
msgid "Holiday color"
msgstr "Ünnepi színe"

#. i18n: ectx: whatsthis, entry, group (Colors)
#. i18n: ectx: whatsthis, entry, group (Theming)
#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:325 settings/korganizer.kcfg:530
#: settings/korganizer.kcfg:638
#, kde-format
