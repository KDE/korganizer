#. i18n: ectx: label, entry (AgendaBgColor), group (Colors)
#. i18n: ectx: label, entry, group (Theming)
#: settings/korganizer.kcfg:329 settings/korganizer.kcfg:458
#, kde-format
msgid "Agenda view background color"
msgstr "Napirend nézet háttérszíne"

#. i18n: ectx: whatsthis, entry (AgendaBgColor), group (Colors)
#. i18n: ectx: whatsthis, entry, group (Theming)
#: settings/korganizer.kcfg:330 settings/korganizer.kcfg:459
#, kde-format
msgid "Select the agenda view background color here."
msgstr "Itt válassza ki a napirend nézet háttérszínét."

#. i18n: ectx: label, entry, group (Colors)
#: settings/korganizer.kcfg:334
#, kde-format
msgid "Agenda view current-time (Marcus Bains) line color"
msgstr "Napirend nézet aktuális-idő (Marcus Bains) vonalának színe"

#. i18n: ectx: whatsthis, entry, group (Colors)
#: settings/korganizer.kcfg:335
#, kde-format
msgid "Select a color to use for the current-time (Marcus Bains) line."
msgstr "Válassza ki az aktuális idő (Marcus Bains) vonalhoz használandó színt."

#. i18n: ectx: tooltip, entry, group (Colors)
#: settings/korganizer.kcfg:336
#, kde-format
msgid "Use this color for the Agenda View current-time (Marcus Bains) line"
msgstr "Használja ezt a színt a Naptár nézetben a „Jelenlegi idő” (Marcus Bains) vonalhoz"

#. i18n: ectx: label, entry (ViewBgBusyColor), group (Colors)
#: settings/korganizer.kcfg:340
#, kde-format
msgid "Busy days background color"
msgstr "Foglalt napok háttérszíne"

#. i18n: ectx: whatsthis, entry (ViewBgBusyColor), group (Colors)
#: settings/korganizer.kcfg:341
#, kde-format
msgid ""
"When you have an all day event marked as busy, you can have a different "
"agenda or month view background color for that day. Select the color here."
msgstr "Ha egy napot, egy egész napot elfoglaló eseményként jelölt meg, akkor az adott naphoz eltérő napirendi vagy havi nézeti háttérszínt is megadhat. Válassza ki a színt itt."

#. i18n: ectx: label, entry, group (Colors)
#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:345 settings/korganizer.kcfg:558
#, kde-format
msgid "Working hours color"
msgstr "Munkaidő színes"

#. i18n: ectx: whatsthis, entry, group (Colors)
#: settings/korganizer.kcfg:346
#, kde-format
msgid "Select the working hours color for the agenda view here."
msgstr "Itt válassza ki a munkaidő színét a napirend nézethez."

#. i18n: ectx: label, entry (TodoDueTodayColor), group (Colors)
#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:350 settings/korganizer.kcfg:610
#, kde-format
msgid "To-do due today color"
msgstr "A mai teendők színe"

#. i18n: ectx: whatsthis, entry (TodoDueTodayColor), group (Colors)
#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:351 settings/korganizer.kcfg:611
#, kde-format
msgid "Select the to-do due today color here."
msgstr "Itt válassza ki a ma esedékes teendők színét."

#. i18n: ectx: label, entry (TodoOverdueColor), group (Colors)
#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:355 settings/korganizer.kcfg:623
#, kde-format
msgid "To-do overdue color"
msgstr "A lejárt határidejű teendők színe"

#. i18n: ectx: whatsthis, entry (TodoOverdueColor), group (Colors)
#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:356 settings/korganizer.kcfg:624
#, kde-format
msgid "Select the to-do overdue color here."
msgstr "Itt válassza ki a lejárt határidejű teendők színét."

#. i18n: ectx: label, entry (MonthTodayColor), group (Colors)
#: settings/korganizer.kcfg:360
#, kde-format
msgid "Month view today background color"
msgstr "Mai nap háttérszíne a havi nézetben"

#. i18n: ectx: tooltip, entry (MonthTodayColor), group (Colors)
#: settings/korganizer.kcfg:361
#, kde-format
msgid "Set the background color for today's date in month view"
msgstr "A mai nap háttérszínének beállítása a hónap nézetben"

#. i18n: ectx: whatsthis, entry (MonthTodayColor), group (Colors)
#: settings/korganizer.kcfg:362
#, kde-format
msgid "In Month View, select the background color for today's date."
msgstr "Válassza ki a Hónap nézetben, a mai nap háttérszínét."

#. i18n: ectx: label, entry, group (Fonts)
#: settings/korganizer.kcfg:369
#, kde-format
msgid "Time bar"
msgstr "Idősáv"

#. i18n: ectx: whatsthis, entry, group (Fonts)
#: settings/korganizer.kcfg:370
#, kde-format
msgid ""
"Press this button to configure the time bar font. The time bar is the widget "
"that shows the hours in the agenda view. This button will open the \"Select "
"Font\" dialog, allowing you to choose the hour font for the time bar."
msgstr "Nyomja meg ezt a gombot az idősáv betűtípusának beállításához. Az idősáv az a modul, amely az időbeosztást mutatja a napirend nézetben. Ez a gomb megnyitja a \"Betűtípus Kiválasztása\" párbeszédpanelt, amely lehetővé teszi, hogy kiválassza az idősáv betűtípusát."

#. i18n: ectx: label, entry, group (Fonts)
#: settings/korganizer.kcfg:373
#, kde-format
msgid "Month view"
msgstr "Havi nézet"

#. i18n: ectx: whatsthis, entry, group (Fonts)
#: settings/korganizer.kcfg:374
#, kde-format
msgid ""
"Press this button to configure the month view font. This button will open "
"the \"Select Font\" dialog, allowing you to choose the font for the items in "
"the month view."
msgstr "Nyomja meg ezt a gombot a hónap nézet betűtípusának beállításához. Ez a gomb megnyitja a \"Betűtípus Kiválasztása\" párbeszédpanelt, amely lehetővé teszi a hónap nézetben lévő elemek betűtípusának kiválasztását."

#. i18n: ectx: label, entry, group (Fonts)
#: settings/korganizer.kcfg:377
#, kde-format
msgid "Agenda view"
msgstr "Napirend nézet"

#. i18n: ectx: whatsthis, entry, group (Fonts)
#: settings/korganizer.kcfg:378
#, kde-format
msgid ""
"Press this button to configure the agenda view font. This button will open "
"the \"Select Font\" dialog, allowing you to choose the font for the events "
"in the agenda view."
msgstr "Nyomja meg ezt a gombot a napirend nézet betűtípusának beállításához. Ez a gomb megnyitja a \"Betűtípus Kiválasztása\" párbeszédpanelt, amely lehetővé teszi, hogy kiválassza az események betűtípusát a napirend nézetben."

#. i18n: ectx: label, entry, group (Fonts)
#: settings/korganizer.kcfg:381
#, kde-format
msgid "Current-time (Marcus Bains) line"
msgstr "Jelenlegi idő (Marcus Bains) vonal"

#. i18n: ectx: whatsthis, entry, group (Fonts)
#: settings/korganizer.kcfg:382
#, kde-format
msgid ""
"Press this button to configure the current-time (Marcus Bains) line font. "
"This button will open the \"Select Font\" dialog, allowing you to choose the "
"font for the current-time line in the agenda view."
msgstr "Nyomja meg ezt a gombot az aktuális idő (Marcus Bains) vonal betűtípusának beállításához. Ez a gomb megnyitja a \"Betűtípus Kiválasztása\" párbeszédpanelt, amely lehetővé teszi, hogy kiválassza az aktuális idővonal betűtípusát a napirend nézetben."

#. i18n: ectx: label, entry (DefaultTodoAttachMethod), group (Hidden Options)
#: settings/korganizer.kcfg:401
#, kde-format
msgid "Default todo attachment method"
msgstr "Alapértelmezett teendő csatolási módszer"

#. i18n: ectx: whatsthis, entry (DefaultTodoAttachMethod), group (Hidden Options)
#: settings/korganizer.kcfg:402
#, kde-format
msgid "The default way of attaching dropped emails to a task"
msgstr "A beledobott e-mailek feladathoz csatolásának alapértelmezett módja\n"

#. i18n: ectx: label, entry (DefaultTodoAttachMethod), group (Hidden Options)
#: settings/korganizer.kcfg:405
#, kde-format
msgid "Always ask"
msgstr "Rákérdezés mindig"

#. i18n: ectx: label, entry (DefaultTodoAttachMethod), group (Hidden Options)
#: settings/korganizer.kcfg:408
#, kde-format
msgid "Only attach link to message"
msgstr "Csak linket csatoljon az üzenethez"

#. i18n: ectx: label, entry (DefaultTodoAttachMethod), group (Hidden Options)
#: settings/korganizer.kcfg:411
#, kde-format
msgid "Attach complete message"
msgstr "Csatolja a teljes üzenetet"

#. i18n: ectx: label, entry, group (Theming)
#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:465 settings/korganizer.kcfg:553
#, kde-format
msgid "Highlight color"
msgstr "Kiemelő szín"

#. i18n: ectx: whatsthis, entry, group (Theming)
#: settings/korganizer.kcfg:466
#, kde-format
msgid ""
"Select the highlight color here. The highlight color will be used for "
"marking the currently selected area in your agenda and in the date navigator."
msgstr "Itt válassza ki a kiemelő színét. A kiemelő szín az aktuálisan kiválasztott terület megjelölésére szolgál a napirendben és a dátumnavigátorban."

#. i18n: ectx: label, entry, group (Theming)
#: settings/korganizer.kcfg:534
#, kde-format
msgid "Use system colors for some background colors"
msgstr "Rendszerszínek használata egyes háttérszínekhez"

#. i18n: ectx: tooltip, entry, group (Theming)
#: settings/korganizer.kcfg:535
#, kde-format
msgid "Use system colors instead of custom colors for some background colors"
msgstr "Rendszerszínek használata az egyéni színek helyett, egyes háttérszínhez"

#. i18n: ectx: whatsthis, entry, group (Theming)
#: settings/korganizer.kcfg:536
#, kde-format
msgid ""
"Use system colors instead of user defined colors for the \"Agenda view "
"background color\", \"Busy days background color\" and the \"Working hours "
"color\" (and possibly others)."
msgstr "A \"Napirend nézet háttérszíne\", a \"Foglalt napok háttérszíne\" és a \"Munkaidő színe\" (és esetleg más színek) esetében a felhasználó által meghatározott színek helyett, a rendszerszínek használata."

#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:546
#, kde-format
msgid "Month view background color"
msgstr "Havi nézet háttérszíne"

#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:547
#, kde-format
msgid "Select the Month view background color here."
msgstr "Itt válassza ki a Havi nézet háttérszínét."

#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:554
#, kde-format
msgid ""
"Select the highlight color here. The highlight color will be used for "
"marking the currently selected area in your Month and in the date navigator."
msgstr "Itt válassza ki a kiemelő színét. A kiemelő szín az aktuálisan kiválasztott terület megjelölésére lesz használva a Hónapnézetben és a dátumnavigátorban."

#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:559
#, kde-format
msgid "Select the working hours background color for the Month view here."
msgstr "Itt válassza ki a munkaidő háttérszínét a Hónap nézethez."

#. i18n: ectx: label, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:581
#, kde-format
msgid "Default event color"
msgstr "Alapértelmezett eseményszín"

#. i18n: ectx: whatsthis, entry, group (Theme/Month view)
#: settings/korganizer.kcfg:582
#, kde-format
msgid ""
"Select the default event color here. The default event color will be used "
"for events in your Month. Note that you can specify a separate color for "
"each event tag below."
msgstr "Itt válassza ki az esemény alapértelmezett színét. Az alapértelmezett eseményszín lesz használva a Hónap eseményeihez. Vegye figyelembe, hogy az alábbiakban minden egyes eseménycímkéhez külön színt adhat meg."

#. i18n: ectx: property (placeholderText), widget (KListWidgetSearchLine, searchline)
#: ui/filteredit_base.ui:35
#, kde-format
