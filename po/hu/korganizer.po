msgid "In Vertically"
msgstr "Függőlegesen Befelé"

#: actionmanager.cpp:455
#, kde-format
msgctxt "@action:inmenu"
msgid "Out Vertically"
msgstr "Függőlegesen Kifelé"

#: actionmanager.cpp:464
