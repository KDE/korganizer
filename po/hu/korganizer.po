msgid "Scroll Backward"
msgstr "Visszafelé Görgetés"

#: actionmanager.cpp:478
#, kde-format
msgctxt "@info:tooltip"
msgid "Scroll the view backward"
msgstr "A nézet görgetése visszafelé"

#: actionmanager.cpp:480
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Scrolls backward by a day, week, month or year, depending on the current "
"calendar view."
msgstr "Az aktuális naptári nézettől függően, egy napot, hetet, hónapot vagy évet görget visszafelé."

#: actionmanager.cpp:487
#, kde-format
msgctxt "@action:inmenu scroll forward"
msgid "&Forward"
msgstr "&Előre"

#: actionmanager.cpp:489
#, kde-format
