msgstr "Előre"

#: actionmanager.cpp:490
#, kde-format
msgctxt "@info:status"
msgid "Scroll Forward"
msgstr "Előre Görgetés"

#: actionmanager.cpp:491
#, kde-format
msgctxt "@info:tooltip"
msgid "Scroll the view forward"
msgstr "A nézet görgetése előre"

#: actionmanager.cpp:493
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Scrolls forward by a day, week, month or year, depending on the current "
"calendar view."
msgstr "Az aktuális naptári nézettől függően, egy napot, hetet, hónapot vagy évet görget előre."

#: actionmanager.cpp:499
#, kde-format
msgctxt "@action:inmenu"
msgid "&Day"
msgstr "&Nap"

#: actionmanager.cpp:500
#, kde-format
msgctxt "@action:inmenu agenda view show 1 day at a time"
msgid "Day"
msgstr "Nap"

#: actionmanager.cpp:501
#, kde-format
msgctxt "@info:status"
msgid "View 1 day at a time"
msgstr "Egyszerre 1 nap megtekintése"

#: actionmanager.cpp:502
#, kde-format
msgctxt "@info:tooltip"
msgid "Show 1 day at a time in Agenda View"
msgstr "Egyszerre 1 nap megjelenítése a Napirend Nézetben"

#: actionmanager.cpp:503
#, kde-format
msgctxt "@info:whatsthis"
msgid "Select this option to show only 1 day at a time in Agenda View."
msgstr "Válassza ezt a lehetőséget, ha egyszerre csak 1 napot szeretne megjeleníteni a Napirend Nézetben."

#: actionmanager.cpp:510
#, kde-format
msgctxt "@action:inmenu agenda view show a few days at a time"
msgid "&Next Days"
msgstr "&Következő Napok"

#: actionmanager.cpp:511
#, kde-format
msgctxt "@info:status"
